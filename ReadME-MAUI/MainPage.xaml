<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ReadME_MAUI.Models"
             x:Class="ReadME_MAUI.MainPage">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Ajouter" Clicked="ImportBook" Order="Primary"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        <!--<SearchBar Grid.Row="0" Placeholder="Rechercher un livre..." Margin="10,5" />-->
        <CollectionView Grid.Row="1" ItemsSource="{Binding MyBooks}" Margin="10,10,10,40" SelectionMode="Single" SelectionChanged="OnSelectedBook">
            <!--Binding indique qu'on connecte xaml avec c# pour récuperér la liste et que on la parcourt ici-->
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="20" VerticalItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <VerticalStackLayout Spacing="5" WidthRequest="140">
                        <Border HeightRequest="200" WidthRequest="140">
                            <Image Source="{Binding Cover}" Aspect="AspectFill" BackgroundColor="LightGray" />
                        </Border>

                        <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                            <Label Grid.Column="0" Text="{Binding Title}" 
                                   FontAttributes="Bold" FontSize="16" Margin="0, 2"  LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1" Text="⋮" FontSize="16" FontAttributes="Bold"
                                   VerticalOptions="Center" HorizontalOptions="End" Padding="6,2">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBookOptionsTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <Label Text="{Binding Author}" FontSize="13" TextColor="Gray" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>