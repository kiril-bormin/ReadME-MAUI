<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadME_MAUI.ReaderPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,15,20,0">
            <Label x:Name="TopTitleLabel" Text="Titre du livre" 
                   HorizontalOptions="Center" TextColor="Gray" FontSize="14" />
            <Label Grid.Column="1" x:Name="PercentageLabel" Text="0%" 
                   TextColor="Gray" FontSize="14" />
        </Grid>

        <WebView Grid.Row="1" x:Name="BookWebview" />

        <!-- Boutons navigation -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *" Padding="20,10,20,30" ColumnSpacing="10">
            <Button Grid.Column="0" Text="← Précédent"
                    Clicked="OnPreviousPageClicked"
                    BackgroundColor="#EEEEEE"
                    TextColor="#333333"
                    FontSize="14"
                    CornerRadius="8" />
            <Button Grid.Column="1" Text="Suivant →"
                    Clicked="OnNextPageClicked"
                    BackgroundColor="#EEEEEE"
                    TextColor="#333333"
                    FontSize="14"
                    CornerRadius="8" />
        </Grid>

    </Grid>
</ContentPage>